# En production, le front (déployé sur Cloudflare Pages via git push) tape
# l'API du Worker déployé séparément — c'est lui qui a le binding D1.
# Sans cette variable, le fetch("/api/*") tombe sur le domaine Pages, qui
# ne connaît pas l'API et renvoie du HTML (SPA fallback) → aucune sync.
VITE_API_BASE=https://nesis-timetrack.c-chaput634.workers.dev/api
